<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX v3 installer source for dbboard (ADR-0032).

  Built with cargo-wix: `cargo wix` from apps/dbboard. cargo-wix defines
  $(var.Version) from Cargo.toml and $(var.CargoTargetBinDir) as the
  profile's bin dir, and runs candle/light from the package root, so the
  relative SourceFile paths below resolve against apps/dbboard.

  The UpgradeCode and the PATH component Guid are FIXED on purpose:
  changing them breaks in-place upgrades and PATH cleanup on uninstall.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="dbboard"
        UpgradeCode="A8AED330-48F5-4C84-89AD-C1303DF5543F"
        Manufacturer="meta-taro"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package Id="*"
            Keywords="Installer"
            Description="dbboard — desktop client for serverless databases"
            Manufacturer="meta-taro"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252"/>

        <!-- Block downgrades; replace an older install cleanly. -->
        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit."/>

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="dbboard Installation"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="dbboard">
                    <!--
                      Optional PATH entry so `dbboard` is runnable from a
                      terminal. Fixed Guid + KeyPath because an Environment
                      table row has no versioned file to key on.
                    -->
                    <Component Id="Path" Guid="B008E00A-3525-4A0F-AF0E-DF2045D814B2" KeyPath="yes">
                        <Environment
                            Id="PATH"
                            Name="PATH"
                            Value="[APPLICATIONFOLDER]"
                            Permanent="no"
                            Part="last"
                            Action="set"
                            System="yes"/>
                    </Component>

                    <Component Id="binary0" Guid="*">
                        <File
                            Id="exe0"
                            Name="dbboard.exe"
                            DiskId="1"
                            Source="$(var.CargoTargetBinDir)\dbboard.exe"
                            KeyPath="yes"/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id="Binaries"
            Title="Application"
            Description="Installs the dbboard executable."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            Absent="disallow">
            <ComponentRef Id="binary0"/>

            <Feature
                Id="Environment"
                Title="PATH Environment Variable"
                Description="Add the install directory to PATH so dbboard is runnable from any terminal."
                Level="1">
                <ComponentRef Id="Path"/>
            </Feature>
        </Feature>

        <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize"/>

        <!-- Add/Remove Programs icon. -->
        <Icon Id="ProductICO" SourceFile="assets\dbboard.ico"/>
        <Property Id="ARPPRODUCTICON" Value="ProductICO"/>
        <Property Id="ARPHELPLINK" Value="https://github.com/meta-taro/dbboard"/>

        <!--
          Allow the install directory to be changed, then show the license.
          WixUI_FeatureTree lets the user opt out of the PATH sub-feature.
        -->
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER"/>
        <WixVariable Id="WixUILicenseRtf" Value="wix\License.rtf"/>
        <UIRef Id="WixUI_FeatureTree"/>
    </Product>
</Wix>

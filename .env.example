# dbboard environment configuration.
#
# Copy to `.env` and fill in as needed. The app picks its backend from
# these variables at startup, in priority order: Postgres URL, then a
# fully configured D1, then local Turso. With none set, it opens an
# in-memory Turso/libSQL database and runs without any configuration.
#
# Do NOT commit a real `.env` — DBBOARD_D1_TOKEN and the password inside
# DBBOARD_PG_URL are secrets.

# --- Local Turso / libSQL (default backend) ---------------------------
# Path to a libSQL database file, or ":memory:" for an ephemeral one.
# DBBOARD_TURSO_PATH=:memory:

# --- Cloudflare D1 (REST API) -----------------------------------------
# Set ALL THREE of the following to connect to D1 instead of Turso.
# A partial setup is ignored and the app falls back to Turso.
#
# Account and database IDs: Cloudflare dashboard (Workers & Pages -> D1)
# or `wrangler d1 info <database-name>`.
# DBBOARD_D1_ACCOUNT_ID=your-cloudflare-account-id
# DBBOARD_D1_DATABASE_ID=your-d1-database-id
#
# API token with the "D1 Edit" permission (My Profile -> API Tokens).
# DBBOARD_D1_TOKEN=your-api-token
#
# Optional: override the API root (defaults to the URL below).
# DBBOARD_D1_BASE_URL=https://api.cloudflare.com/client/v4

# --- CockroachDB / PostgreSQL (sqlx, PostgreSQL wire protocol) ---------
# A single connection string connects to CockroachDB (Cloud Basic free
# tier or self-hosted) or any PostgreSQL-wire database such as Neon.
# Takes precedence over the D1 and Turso variables above.
#
# CockroachDB Cloud: copy the string from the cluster's Connect dialog.
# Self-hosted: the default SQL port is 26257. TLS is required, so keep
# sslmode=verify-full (or the mode your deployment expects).
#
# Contains a password — never commit a real value.
# DBBOARD_PG_URL=postgresql://user:pass@host:26257/db?sslmode=verify-full

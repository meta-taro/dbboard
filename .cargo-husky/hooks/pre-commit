#!/usr/bin/env sh
#
# dbboard pre-commit hook
#
# Installed automatically by cargo-husky on first `cargo test`.
# See CLAUDE.md "Mandatory Verification Commands".

set -e

# GUI git clients (GitHub Desktop, GitKraken, …) launch hooks with a
# minimal PATH that omits the user's cargo install. Add the standard
# rustup location so the hook works regardless of the launching shell.
export PATH="$HOME/.cargo/bin:$PATH"

# PII / secret leak scan first — fail fast before the slower cargo gates so a
# leaked store name or credential never reaches a commit. --reveal is safe
# here: local hook output is not a public log. See docs/maintainer/pii-scanning.md.
# Fail CLOSED: if the scanner is tracked but missing from the working tree
# (bad rebase, partial checkout, tampering) do NOT silently skip the scan.
if [ -f scripts/pii-scan.sh ]; then
    echo "[pre-commit] scripts/pii-scan.sh --staged"
    sh scripts/pii-scan.sh --staged --reveal
elif git ls-files --error-unmatch scripts/pii-scan.sh >/dev/null 2>&1; then
    echo "[pre-commit] ERROR: scripts/pii-scan.sh is tracked but missing — refusing to commit without the PII scan." >&2
    exit 1
fi

echo "[pre-commit] cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "[pre-commit] cargo clippy --all-targets --all-features -- -D warnings"
cargo clippy --all-targets --all-features -- -D warnings

echo "[pre-commit] cargo check --all-targets --all-features"
cargo check --all-targets --all-features

echo "[pre-commit] cargo test --all-features"
cargo test --all-features

echo "[pre-commit] ok"
